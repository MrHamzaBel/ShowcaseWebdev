@model IEnumerable<Showcase_Chat.Models.Message>
@{
    ViewData["Title"] = "Chat";
}

<div class="row">
    <div class="col-12">
        <h2 class="mb-3">Chatroom</h2>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <!-- Vue 3 chat component wordt hier gemount (US5) -->
        <div id="chat-app"
             data-hub-url="/chatHub"
             data-username="@User.Identity!.Name">
        </div>

        <!-- Fallback: werkt zonder JavaScript / als SignalR niet beschikbaar is -->
        <noscript>
            <div class="card mt-3">
                <div class="card-header">Berichten (no-JS fallback)</div>
                <ul class="list-group list-group-flush" style="max-height:400px;overflow-y:auto">
                    @foreach (var msg in Model)
                    {
                        <li class="list-group-item">
                            <strong>@msg.Sender.DisplayName</strong>
                            <span class="text-muted small ms-2">@msg.CreatedAt.ToLocalTime().ToString("HH:mm")</span>
                            <p class="mb-0">@msg.Content</p>
                        </li>
                    }
                </ul>
                <div class="card-footer">
                    <form asp-action="Send" method="post">
                        @Html.AntiForgeryToken()
                        <div class="input-group">
                            <input name="content" class="form-control" placeholder="Typ een bericht..." maxlength="1000" required />
                            <button class="btn btn-primary" type="submit">Verzenden</button>
                        </div>
                    </form>
                </div>
            </div>
        </noscript>

        @if (User.IsInRole("Admin"))
        {
            <div class="mt-3">
                <a asp-controller="Admin" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    Admin: alle berichten bekijken
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <!-- SignalR JS client (ingebouwd in ASP.NET Core) -->
    <script src="~/lib/microsoft-signalr/dist/browser/signalr.min.js"></script>
    <!-- Vue 3 chat component (gebouwd met Vite) -->
    <script src="~/js/chat-app.js" type="module"></script>
}
