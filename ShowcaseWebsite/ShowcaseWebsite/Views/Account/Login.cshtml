@model ShowcaseWebsite.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Inloggen";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card bg-dark border-secondary p-4">
            <h1 class="h4 mb-4">Inloggen</h1>

            <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control bg-dark text-light border-secondary"
                           placeholder="uw@email.nl" autofocus />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control bg-dark text-light border-secondary"
                           placeholder="Wachtwoord" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label text-secondary small"></label>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <button type="submit" class="btn btn-primary w-100">Inloggen</button>
            </form>

            <hr class="border-secondary my-3">
            <p class="text-center small text-secondary">
                Nog geen account?
                <a asp-action="Register" class="text-success">Registreren</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
