@using ShowcaseWebsite.Models
@model List<Message>
@{
    ViewData["Title"] = "Admin – Alle berichten";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Admin dashboard – berichten</h1>
    <a asp-action="FilterByUser" class="btn btn-sm btn-outline-secondary">Filter op gebruiker</a>
</div>

<div class="table-responsive">
    <table class="table table-dark table-bordered table-hover table-sm">
        <thead class="table-secondary text-dark">
            <tr>
                <th>#</th>
                <th>Gebruiker</th>
                <th>Bericht</th>
                <th>Tijdstip</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var msg in Model)
            {
                <tr>
                    <td>@msg.Id</td>
                    <td class="text-success">@msg.UserName</td>
                    <!-- @msg.Content wordt automatisch door Razor ge-HTML-encoded (XSS-bescherming) -->
                    <td>@msg.Content</td>
                    <td class="text-secondary small">@msg.SentAt.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <p class="text-secondary">Geen berichten gevonden.</p>
}
