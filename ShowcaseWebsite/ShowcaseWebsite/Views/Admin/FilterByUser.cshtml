@using ShowcaseWebsite.Models
@model List<Message>
@{
    ViewData["Title"] = "Admin – Filter op gebruiker";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Berichten filteren</h1>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Alle berichten</a>
</div>

<form asp-action="FilterByUser" method="get" class="d-flex gap-2 mb-4">
    <select name="userName" class="form-select bg-dark text-light border-secondary w-auto">
        <option value="">— Alle gebruikers —</option>
        @foreach (var user in (ViewBag.Users as List<ApplicationUser> ?? new()))
        {
            <option value="@user.UserName"
                    selected="@(user.UserName == ViewBag.SelectedUser ? "selected" : null)">
                @user.UserName
            </option>
        }
    </select>
    <button type="submit" class="btn btn-primary">Filter</button>
</form>

<div class="table-responsive">
    <table class="table table-dark table-bordered table-hover table-sm">
        <thead class="table-secondary text-dark">
            <tr>
                <th>#</th>
                <th>Gebruiker</th>
                <th>Bericht</th>
                <th>Tijdstip</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var msg in Model)
            {
                <tr>
                    <td>@msg.Id</td>
                    <td class="text-success">@msg.UserName</td>
                    <td>@msg.Content</td>
                    <td class="text-secondary small">@msg.SentAt.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <p class="text-secondary">Geen berichten gevonden voor deze gebruiker.</p>
}
